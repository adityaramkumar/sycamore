# Copy to .env and edit. All variables are optional; defaults work
# for a single-arm sequential run against a vanilla ./arrow clone.

# ------------------------------------------------------------------
# Target repo location
# ------------------------------------------------------------------
TARGET_REPO_PATH=./arrow

# ------------------------------------------------------------------
# Trace + memory directories
# ------------------------------------------------------------------
# TRACES_DIR=./traces
# MEMORY_DIR=./memory

# ------------------------------------------------------------------
# Model selection
# ------------------------------------------------------------------
# Model alias passed to ClaudeAgentOptions. "haiku", "sonnet", "opus"
# or a full model id. Defaults to haiku.
# AGENT_MODEL=sonnet

# Model used only for the distillation LLM call (coder lesson
# extraction). Falls back to AGENT_MODEL if unset. Useful when you
# want cheap loop agents but a stronger distiller.
# DISTILL_MODEL=sonnet

# ------------------------------------------------------------------
# Coder budget + oracle
# ------------------------------------------------------------------
# MAX_TURNS=40
# ORACLE_TIMEOUT_S=120
# ORACLE_BROADER_CHECK=1      # 0 disables the full-suite regression run

# ------------------------------------------------------------------
# Auth
# ------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...        # direct API mode
# CLI_PATH=/usr/local/bin/claude      # override claude CLI binary path
